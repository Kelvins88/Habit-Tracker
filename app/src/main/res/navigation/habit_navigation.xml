<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/habit_navigation"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.habittracker.view.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_habitListFragment"
            app:destination="@id/habitListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/habitListFragment"
        android:name="com.example.habittracker.view.HabitListFragment"
        android:label="Habit Tracker"
        tools:layout="@layout/fragment_habit_list">
        <action
            android:id="@+id/action_habitListFragment_to_addHabitFragment"
            app:destination="@id/addHabitFragment" />
        <action
            android:id="@+id/action_habitListFragment_to_editHabitFragment"
            app:destination="@id/editHabitFragment" />
    </fragment>

    <fragment
        android:id="@+id/addHabitFragment"
        android:name="com.example.habittracker.view.AddHabitFragment"
        android:label="Create New Habit"
        tools:layout="@layout/fragment_add_habit" >
        <action
            android:id="@+id/action_addHabitFragment_to_habitListFragment"
            app:destination="@id/habitListFragment" />
    </fragment>

    <fragment
        android:id="@+id/editHabitFragment"
        android:name="com.example.habittracker.view.EditHabitFragment"
        android:label="Edit Habit"
        tools:layout="@layout/fragment_edit_habit">
        <argument
            android:name="habitId"
            app:argType="string" />
    </fragment>
</navigation>